PAWIT_ENV=development
PAWIT_ALLOW_DEV_AUTH=true
PAWIT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
PAWIT_TRUSTED_PROXY_CIDRS=
PAWIT_RATE_LIMIT_RPM=120
PAWIT_REQUEST_BODY_LIMIT_BYTES=1048576
PAWIT_DATABASE_URL=postgres://pawit:local-password@localhost:5432/pawit?sslmode=disable
PORT=8080

LIQUIBASE_IMAGE=liquibase/liquibase:4.31.1
LIQUIBASE_COMMAND_URL=jdbc:postgresql://host.docker.internal:5432/pawit
LIQUIBASE_COMMAND_USERNAME=pawit
LIQUIBASE_COMMAND_PASSWORD=local-password
